{
  "datasets": [
    {
      "name": "3f429dcd",
      "displayName": "total",
      "queryLines": [
        "SELECT COUNT(*) AS total_tweets \n",
        "FROM workspace.default.tweets_bronze"
      ]
    },
    {
      "name": "553f337a",
      "displayName": "with_mentions",
      "queryLines": [
        "SELECT COUNT(*) AS tweets_with_mentions \n",
        "FROM workspace.default.tweets_silver\n",
        "WHERE mention IS NOT NULL"
      ]
    },
    {
      "name": "f3625388",
      "displayName": "without_mentions",
      "queryLines": [
        "SELECT COUNT(*) AS tweets_without_mentions \n",
        "FROM workspace.default.tweets_silver\n",
        "WHERE mention IS NULL"
      ]
    },
    {
      "name": "67950d37",
      "displayName": "top_10_users",
      "queryLines": [
        "SELECT user, COUNT(*) AS tweet_count\n",
        "FROM workspace.default.tweets_bronze\n",
        "GROUP BY user\n",
        "ORDER BY tweet_count DESC\n",
        "LIMIT 10"
      ]
    },
    {
      "name": "8c9df73d",
      "displayName": "top_10_pos",
      "queryLines": [
        "SELECT mention, positive\n",
        "FROM workspace.default.gold_tweet_aggregations\n",
        "ORDER BY positive DESC\n",
        "LIMIT 10"
      ]
    },
    {
      "name": "85de95b1",
      "displayName": "top_10_neg",
      "queryLines": [
        "SELECT mention, negative\n",
        "FROM workspace.default.gold_tweet_aggregations\n",
        "ORDER BY negative DESC\n",
        "LIMIT 10"
      ]
    }
  ],
